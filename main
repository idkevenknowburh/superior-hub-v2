local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Displays a custom button frame directly below/beside the key prompt window
Rayfield:Notify({
   Title = "Get Access Key",
   Content = "Need a key? Click below to instantly join our Discord or copy the link!",
   Duration = 60, -- Stays on screen for 60 seconds or until they dismiss it
   Image = nil,
   Actions = {
      ["Join Discord"] = {
         Name = "Join Discord",
         Callback = function()
            -- Triggers compatible executors to join automatically via local protocol
            if request then
               request({
                  Url = "http://127.0.0.1:6463/rpc?v=1",
                  Method = "POST",
                  Headers = { ["Content-Type"] = "application/json", ["Origin"] = "https://discord.com" },
                  Body = game:GetService("HttpService"):JSONEncode({
                     cmd = "INVITE_BROWSER",
                     args = { code = "fwVcCGNnAh" },
                     nonce = game:GetService("HttpService"):GenerateGUID(false)
                  })
               })
            else
               -- Fallback to clipboard if executor doesn't support direct RPC joining
               if setclipboard then setclipboard("https://discord.gg/fwVcCGNnAh") end
            end
         end
      },
      ["Copy Link"] = {
         Name = "Copy Invite Link",
         Callback = function()
            if setclipboard then
               setclipboard("https://discord.gg/fwVcCGNnAh")
            end
         end
      }
   }
})

-- Main key system activation window proceeds normally
local Window = Rayfield:CreateWindow({
   Name = "Sheitsa Hub V2",
   Icon = 0,
   LoadingTitle = "Sheitsa Hub V2",
   LoadingSubtitle = "by Sheitsa",
   ShowText = "Sheitsa Hub V2",
   Theme = "Ocean",
   ToggleUIKeybind = "K",
   DisableRayfieldPrompts = false,
   DisableBuildWarnings = false,

   ConfigurationSaving = {
      Enabled = true,
      FolderName = nil,
      FileName = "Big Hub"
   },

   Discord = {
      Enabled = true,
      Invite = "fwVcCGNnAh",
      RememberJoins = true
   },

   KeySystem = true,
   KeySettings = {
      Title = "Sheitsa Hub V2 | Easy Key",
      Subtitle = "Easy Key Is Located In Discord Server",
      Note = "Check the notifications tab to copy the key invite!",
      FileName = "Key",
      SaveKey = true,
      GrabKeyFromSite = false,
      Key = {"fastkey"}
   }
})

local MainTab = Window:CreateTab("🏠 Home", nil)
local MainSection = MainTab:CreateSection("Main")
